# ─── NexusCompute Cloud — Environment Config ───
# Copy this file to .env and fill in your values
# ALL values are optional at launch — the server runs without any of them

# Claude API key (get free credits at console.anthropic.com — no card needed)
# Leave blank to keep NexusFlow AI in smart-fallback mode
ANTHROPIC_API_KEY=

# Razorpay keys (get from razorpay.com — free account)
# Leave blank to keep payment buttons in "coming soon" mode
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Contact email — where form submissions get logged
# Leave blank to just save to local DB
CONTACT_EMAIL=

# Resend API key for email notifications (resend.com — free, no card)
# Leave blank to skip email sending
RESEND_API_KEY=

# Port (Railway sets this automatically)
PORT=3000

# Your deployed frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080
